{
  "manifest_version": 3,
  "name": "AI Smart Firewall",
  "version": "1.0",
  "description": "AI-powered browser extension that intercepts URLs and blocks phishing, malware, and piracy sites in real-time.",
  "permissions": [
    "webNavigation",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Smart Firewall"
  }
}
